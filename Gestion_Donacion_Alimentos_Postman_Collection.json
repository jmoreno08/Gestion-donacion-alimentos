{
  "info": {
    "name": "Gestion Donacion Alimentos API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:18080"
    },
    {
      "key": "donanteId",
      "value": "1"
    },
    {
      "key": "productoId",
      "value": "1"
    },
    {
      "key": "beneficiarioId",
      "value": "1"
    },
    {
      "key": "entregaId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Donantes",
      "item": [
        {
          "name": "Listar Donantes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/donantes"
          }
        },
        {
          "name": "Consultar Donante",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/donantes/{{donanteId}}"
          }
        },
        {
          "name": "Crear Donante",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/donantes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Donante Postman\",\n  \"tipoDonante\": \"Persona\",\n  \"telefono\": \"3001234567\",\n  \"correo\": \"postman@donante.com\",\n  \"direccion\": \"Cali\"\n}"
            }
          }
        },
        {
          "name": "Actualizar Donante",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/donantes/{{donanteId}}",
            "body": {
              "mode": "raw",
